let_him_cook main() {
    say_my_name("=== FizzBuzz ===")
    run_it_back (trust_me_bro i = 1; i <= 20; i += 1) {
        chat_is_this_real (i % 15 == 0) {
            say_my_name("FizzBuzz no cap")
        }
        wait_hold_up (i % 3 == 0) {
            say_my_name("Fizz fr fr")
        }
        wait_hold_up (i % 5 == 0) {
            say_my_name("Buzz W")
        }
        nah_bro {
            say_my_name(i)
        }
    }
}